{
	"name": "finance-app-mvp",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"wait:database": "node src/infra/scripts/wait-for-postgres.js",
		"services:up": "docker compose up -d",
		"services:down": "docker compose down",
		"pretest": "pnpm services:up && pnpm wait:database",
		"test": "concurrently -n next,vitest --hide next \"next dev\" \"vitest run\" --prefix none --success --ks --k",
		"dev": "pnpm services:up && next dev && pnpm services:down",
		"build": "next build",
		"start": "next start",
		"lint:check": "biome check",
		"lint:fix": "biome format --write"
	},
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.27.0",
	"dependencies": {
		"next": "^16.2.11",
		"pg": "^8.22.0",
