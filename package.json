		"react-dom": "^19.2.8",
		"vite-jsconfig-paths": "^2.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@types/node": "26.1.1",
		"@types/react": "19.2.17",
		"async-retry": "^1.3.3",
		"concurrently": "^10.0.3",
		"dotenv": "^17.4.2",
		"typescript": "7.0.2",
		"vitest": "^4.1.10"
	}
